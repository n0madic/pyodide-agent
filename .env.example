# Copy to .env. Loaded automatically by `deno task start` via --env-file=.env.

# ── LLM provider ──────────────────────────────────────────────
# Default: OpenAI. Leave OPENAI_BASE_URL unset to use api.openai.com.
OPENAI_API_KEY=
MODEL=gpt-4o

# Point at any OpenAI-compatible endpoint by setting OPENAI_BASE_URL:
# OPENAI_BASE_URL=http://localhost:11434/v1        # Ollama
# OPENAI_BASE_URL=http://localhost:1234/v1         # LM Studio
# OPENAI_BASE_URL=https://openrouter.ai/api/v1     # OpenRouter
# OPENAI_BASE_URL=https://api.deepseek.com/v1      # DeepSeek
# OPENAI_BASE_URL=https://api.groq.com/openai/v1   # Groq

# ── Agent limits ──────────────────────────────────────────────
MAX_ITERATIONS=20

# ── Pyodide packages to preload (comma-separated; 'none' = bare) ───
# Defaults to pyyaml,python-dateutil (~214MB RSS, ~800ms cold start).
# Add numpy (+60MB, +0.3s) or pandas (+280MB, +1.3s — also pulls numpy).
# Override via --packages flag on the CLI too.
# PYODIDE_PACKAGES=pyyaml,python-dateutil,numpy,pandas
