{
  "unstable": ["worker-options"],
  "tasks": {
    "start": "sh scripts/start.sh",
    "start:docker": "sh /home/agent/app/scripts/start.sh",
    "start:net": "sh scripts/start.sh --net",
    "start:unsafe": "sh scripts/start.sh --unsafe",
    "check": "deno check src/main.ts",
    "test": "deno test --allow-read --allow-write --allow-run --allow-env --allow-net=cdn.jsdelivr.net tests/",
    "compile": "deno compile --allow-env=* --allow-read --allow-write --allow-net --allow-import --include src/pyodide-worker.ts --output pyodide-agent src/main.ts"
  },
  "imports": {
    "commander": "npm:commander@^13.0.0",
    "openai": "npm:openai@^6.1.0",
    "pyodide": "npm:pyodide@^0.29.3",
    "pyodide/": "npm:/pyodide@^0.29.3/",
    "@std/path": "jsr:@std/path@^1.0.0",
    "marked": "npm:marked@^14.0.0",
    "marked-terminal": "npm:marked-terminal@^7.0.0"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window"]
  },
  "lock": true
}
